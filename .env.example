# Local: copie para .env (este arquivo NAO contem chave real)
WEB3FORMS_ACCESS_KEY=sua_chave_web3forms_aqui

# GitHub Pages / Actions:
# Crie o SECRET com o nome exato: WEB3FORMS_ACCESS_KEY
# Settings > Secrets and variables > Actions
# (ou Environment github-pages)
#
# Nunca commite js/config.js nem .env — o workflow gera o config
# somente no artifact de deploy.
